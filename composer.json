{
    "name": "arduino/cli-backend-api",
    "description": "Arduino CLI Backend API with MCP Server",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.1",
        "mcp/sdk": "^0.5",
        "nyholm/psr7": "^1.8",
        "symfony/finder": "^7.4"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    },
    "scripts": {
        "mcp-server": "php mcp/server.php",
        "mcp-check": "php -l mcp/server.php && php -l public/mcp.php"
    }
}
